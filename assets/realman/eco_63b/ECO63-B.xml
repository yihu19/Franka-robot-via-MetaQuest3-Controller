<mujoco model="ECO63-B-URDF">
  <compiler angle="radian" meshdir="./meshes/" autolimits="true"/>

  <option integrator="implicitfast"/>

  <default>
      <default class="ur5e">
          <material specular="0.5" shininess="0.25"/>
          <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
          <general gaintype="fixed" biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="4000" biasprm="0 -4000 -400"
              forcerange="-150 150"/>

          <default class="size3">

              <default class="size3_limited">
                  <joint range="-3.1415 3.1415"/>
                  <general ctrlrange="-3.1415 3.1415"/>
              </default>

              <default class="size3_joint1">
                  <general gainprm="15000" biasprm="0 -15000 0" forcerange="-1000 1000"/>
              </default>

          </default>

          <default class="size1">
              <general gainprm="1000" biasprm="0 -1000 -100" forcerange="-28 28"/>
          </default>

          <default class="visual">
              <geom type="mesh" contype="0" conaffinity="0" group="2"/>
          </default>

          <default class="collision">
              <geom type="capsule" group="3"/>
              <default class="eef_collision">
                  <geom type="cylinder"/>
              </default>
          </default>
          
          <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>

          <default class="position">
              <position ctrlrange="-6.28319 6.28319" kp="2000" kv="100" forcerange="-150 150"/>
              <default class="position_limited">
                  <position ctrlrange="-3.1415 3.1415"/>
              </default>
              <default class="position_small">
                  <position kp="500" kv="25" forcerange="-28 28"/>
              </default>
              <default class="position_large">
                  <position kp="10000" kv="500" forcerange="-200 200"/>
              </default>
          </default>

      </default>
  </default>  

  <size njmax="500" nconmax="100" />

  <visual>
      <map force="0.1" zfar="30"/>
      <rgba haze="0.15 0.25 0.35 1"/>
      <quality shadowsize="2048"/>
      <global offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <mesh name="base_link" file="base_link.STL"/>
    <mesh name="Link1" file="Link1.STL"/>
    <mesh name="Link2" file="Link2.STL"/>
    <mesh name="Link3" file="Link3.STL"/>
    <mesh name="Link4" file="Link4.STL"/>
    <mesh name="Link5" file="Link5.STL"/>
    <mesh name="Link6" file="Link6.STL"/>
  </asset>

  <worldbody>
    <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.792157 0.819608 0.933333 1" mesh="base_link"/>
    <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="base_link"/>

    <!-- 俯视相机 -->
    <camera name="top" pos="-0.50 0 1.5" quat="0 0 0 1" fovy="100"/>
    <!-- 侧视相机 -->
    <camera name="side" pos="-0.5 1 0.5" quat="0 0 0.70710678 0.70710678" fovy="80"/>   

    <body name="Link1" pos="0 0 0.1625">
