            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
      <position class="position" name="motor_1" joint="joint_1"/>
      <position class="position" name="motor_2" joint="joint_2"/>
      <position class="position_limited" name="motor_3" joint="joint_3"/>
      <position class="position_small" name="motor_4" joint="joint_4"/>
      <position class="position_small" name="motor_5" joint="joint_5"/>
      <position class="position_small" name="motor_6" joint="joint_6"/>
  </actuator>

  <keyframe>
      <key name="home" 
                qpos="0.0331 0.8125 -1.4809 -0.2919 1.4877 0.0" 
                ctrl="0.0331 0.8125 -1.4809 -0.2919 1.4877 0.0"/>
      <key name="zero"
                qpos="0 0 0 0 0 0"
                ctrl="0 0 0 0 0 0"/>
  </keyframe>

</mujoco>
